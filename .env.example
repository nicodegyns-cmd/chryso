# PostgreSQL Connection String (from Supabase)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres

# Public API URL (used by frontend)
# For local development: http://localhost:3000
# For production on Vercel: https://your-domain.vercel.app
NEXT_PUBLIC_API_URL=https://your-domain.vercel.app

# Google OAuth (optional, for production)
# Get these from: https://console.developers.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT Secret (for session tokens)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# eBrigade Integration (Phase 7)
# The eBrigade API base URL
EBRIGADE_URL=http://127.0.0.1/ebrigade
# eBrigade API authentication token
EBRIGADE_TOKEN=your-ebrigade-token-here

