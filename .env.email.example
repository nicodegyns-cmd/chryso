# Email Configuration Guide
# =========================

# Choose email provider: "gmail", "sendgrid", or "smtp"
EMAIL_PROVIDER=smtp

# For Gmail configuration:
# 1. Enable 2FA on your Google Account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the app password below (16 characters)
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# For SendGrid configuration:
# 1. Get your API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx

# For generic SMTP configuration:
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@example.com

# Application configuration
APP_NAME=Chryso
APP_URL=https://www.sirona-consult.be

# Example for Gmail:
# EMAIL_PROVIDER=gmail
# GMAIL_USER=admin@example.com
# GMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Example for SendGrid:
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx

# Example for generic SMTP (like office 365):
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=admin@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@example.com
